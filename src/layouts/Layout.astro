---
import { getEntry } from 'astro:content';

export interface Props {
	title: string;
	description?: string;
	socialDescription?: string;
}

function normalizeStringProp(
	name: string,
	value: unknown,
	options: { optional?: boolean } = {}
): string | undefined {
	if (value == null) {
		if (options.optional) return undefined;
		throw new Error(`Layout.astro requires \`${name}\` prop to be provided`);
	}

	if (typeof value !== 'string') {
		throw new Error(
			`Layout.astro requires \`${name}\` prop to be a string${options.optional ? ' when provided' : ''}; received: ${typeof value}`
		);
	}

	const trimmed = value.trim();
	if (!trimmed) {
		if (options.optional) return undefined;
		throw new Error(`Layout.astro requires a non-empty \`${name}\` prop`);
	}

	return trimmed;
}

const { title: rawTitle, description: rawDescription, socialDescription: rawSocialDescription } =
	Astro.props;

const title = normalizeStringProp('title', rawTitle);
if (!title) {
	throw new Error('Layout.astro requires a non-empty `title` prop');
}

let description = normalizeStringProp('description', rawDescription, {
	optional: true,
});
if (!description) {
	const siteEntry = await getEntry('site', 'site');
	if (!siteEntry) {
		throw new Error(
			'Missing content entry: site/site (while resolving layout meta description)'
		);
	}

	description =
		siteEntry.data.seo?.description?.trim() ||
		siteEntry.data.description?.trim() ||
		siteEntry.data.title?.trim() ||
		siteEntry.data.tagline?.trim() ||
		title;
}

let socialDescription = normalizeStringProp('socialDescription', rawSocialDescription, {
	optional: true,
});
if (!socialDescription) socialDescription = description;

const ogImagePath = '/images/tw_og_logo.jpg';

let siteUrl: string | undefined;
try {
	siteUrl = Astro.site ? new URL(Astro.site).origin : undefined;
} catch (error) {
	const message =
		'Invalid Astro.site URL; OG/Twitter absolute URLs will be omitted. Please fix `site` in astro.config.mjs.';
	if (import.meta.env.DEV) {
		console.warn(message, error);
	} else {
		console.error(message, error);
	}
	siteUrl = undefined;
}
const pathname = Astro.url?.pathname;
const pageUrl = siteUrl && pathname ? new URL(pathname, siteUrl).toString() : undefined;
const ogImageUrl = siteUrl ? new URL(ogImagePath, siteUrl).toString() : undefined;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		{pageUrl && <meta property="og:url" content={pageUrl} />}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={socialDescription} />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{ogImageUrl ? (
			<meta name="twitter:card" content="summary_large_image" />
		) : (
			<meta name="twitter:card" content="summary" />
		)}
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={socialDescription} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Lexend:wght@400;600;800&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--color-bg: #0a0a0a;
		--color-text: #ededeb;     /* off-white, near-neutral. Never pure. */
		--color-muted: #888888;
		--color-dim: #555555;
		--color-rule: #1a1a1a;
		--color-rule-strong: #2a2a2a;
		--font-serif: 'Newsreader', Georgia, serif;
		--font-sans: 'Inter', system-ui, sans-serif;
		--font-mono: 'JetBrains Mono', ui-monospace, monospace;
		--font-display: 'Lexend', system-ui, sans-serif;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: var(--font-sans);
		background: var(--color-bg);
		color: var(--color-text);
		font-size: 15px;
		line-height: 1.55;
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
	}

	#signup {
		scroll-margin-top: 8rem;
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	@keyframes tw-pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.35; }
	}

	@keyframes tw-scroll {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	@keyframes tw-bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(4px); }
	}
</style>
