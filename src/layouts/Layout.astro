---
import { getEntry } from 'astro:content';

export interface Props {
	title: string;
	description?: string;
}

const { title: rawTitle, description: rawDescription } = Astro.props;

if (rawDescription != null && typeof rawDescription !== 'string') {
	throw new Error(
		`Layout.astro requires \`description\` prop to be a string when provided; received: ${typeof rawDescription}`
	);
}

if (typeof rawTitle !== 'string') {
	throw new Error(
		`Layout.astro requires \`title\` prop to be a string; received: ${typeof rawTitle}`
	);
}

const title = rawTitle.trim();
if (!title) {
	throw new Error('Layout.astro requires a non-empty `title` prop');
}

let description =
	typeof rawDescription === 'string' ? rawDescription.trim() : undefined;
if (!description) {
	const siteEntry = await getEntry('site', 'site');
	if (!siteEntry) {
		throw new Error(
			'Missing content entry: site/site (while resolving layout meta description)'
		);
	}

	description =
		siteEntry.data.seo?.description?.trim() ||
		siteEntry.data.description?.trim() ||
		siteEntry.data.title?.trim() ||
		siteEntry.data.tagline?.trim() ||
		title;
}
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--color-bg: #111111;
		--color-text: #f0ede8;
		--color-accent: #e1a24a;
		--color-muted: rgba(240, 237, 232, 0.5);
		--font-heading: 'Lexend', sans-serif;
		--font-body: 'Lexend', sans-serif;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: var(--font-body);
		background: var(--color-bg);
		color: var(--color-text);
		line-height: 1.5;
		scroll-behavior: smooth;
	}

	#signup {
		scroll-margin-top: 12rem;
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}
</style>
