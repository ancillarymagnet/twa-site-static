---
import { getEntry } from 'astro:content';

export interface Props {
	title: string;
	description?: string;
}

const { title: rawTitle, description: rawDescription } = Astro.props;

if (import.meta.env.MODE !== 'production') {
	if (typeof rawTitle !== 'string') {
		throw new Error('Layout.astro requires a string `title` prop');
	}
	if (rawDescription != null && typeof rawDescription !== 'string') {
		console.warn(
			'Layout.astro received a non-string `description` prop; it will be ignored.'
		);
	}
}

const safeTitle = (typeof rawTitle === 'string' ? rawTitle : '').trim();
const title = safeTitle || 'Third Wave';

let description =
	typeof rawDescription === 'string' ? rawDescription.trim() : undefined;
if (!description) {
	const siteEntry = await getEntry('site', 'site');

	if (siteEntry) {
		description =
			siteEntry.data.seo?.description?.trim() ||
			siteEntry.data.description?.trim() ||
			siteEntry.data.title?.trim() ||
			siteEntry.data.tagline?.trim();
	} else {
		const message =
			'Missing content entry: site/site (while resolving layout meta description); falling back to page title.';
		if (import.meta.env.MODE !== 'production') {
			console.warn(message);
		} else {
			console.error(message);
		}
	}

	description = description || title;
}
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--color-bg: #111111;
		--color-text: #f0ede8;
		--color-accent: #e1a24a;
		--color-muted: rgba(240, 237, 232, 0.5);
		--font-heading: 'Lexend', sans-serif;
		--font-body: 'Lexend', sans-serif;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: var(--font-body);
		background: var(--color-bg);
		color: var(--color-text);
		line-height: 1.5;
		scroll-behavior: smooth;
	}

	#signup {
		scroll-margin-top: 12rem;
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}
</style>
