---
export interface Props {
	status: string;
	meta: string;
	metaHref?: string;
}

const { status, meta, metaHref } = Astro.props;
---

<div class="top-bar">
	<span class="ticket"><span class="dot" aria-hidden="true"></span>{status}</span>
	{metaHref
		? <a class="meta meta-link" href={metaHref}>{meta}</a>
		: <span class="meta">{meta}</span>
	}
</div>

<style>
	.top-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--font-label);
		font-size: 12px;
		color: #888;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.ticket {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-text);
		box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
		animation: tw-pulse 1.8s ease-in-out infinite;
	}

	.meta-link {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.meta-link:hover { color: var(--color-text); }

	@media (max-width: 820px) {
		.top-bar { font-size: 10px; letter-spacing: 0.14em; }
	}
</style>
