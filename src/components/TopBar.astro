---
export interface Props {
	status: string;
	meta?: string;
}

const { status, meta } = Astro.props;
---

<div class="top-bar">
	<div class="brand">
		<a class="wordmark" href="/">Third Wave</a>
		<span class="ticket"><span class="dot" aria-hidden="true"></span>{status}</span>
	</div>
	{meta && <span class="meta">{meta}</span>}
</div>

<style>
	.top-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--font-label);
		font-size: 12px;
		color: #888;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 20px;
		min-width: 0;
	}

	.wordmark {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 15px;
		letter-spacing: -0.02em;
		text-transform: uppercase;
		color: var(--color-text);
		text-decoration: none;
		white-space: nowrap;
	}

	.ticket {
		display: flex;
		align-items: center;
		gap: 8px;
		white-space: nowrap;
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-text);
		box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
		animation: tw-pulse 1.8s ease-in-out infinite;
	}

	@media (max-width: 820px) {
		.top-bar { font-size: 10px; letter-spacing: 0.14em; }
		.brand { gap: 14px; }
		.wordmark { font-size: 14px; }
	}

	@media (max-width: 480px) {
		.meta { display: none; }
		.brand { flex: 1; justify-content: space-between; }
	}
</style>
