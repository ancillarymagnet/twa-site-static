---
export interface Video {
	id: string;
	title: string;
	duration?: string;
	label?: string;
}

export interface Props {
	title?: string;
	cta?: string;
	channelUrl?: string;
	videos: Video[];
}

const { title, cta, channelUrl, videos } = Astro.props;

const thumb = (id: string, fallback = false) =>
	`https://img.youtube.com/vi/${id}/${fallback ? 'hqdefault' : 'maxresdefault'}.jpg`;
---

<section class="reel">
	{(title || (cta && channelUrl)) && (
		<div class="reel-head">
			{title ? <h2 class="reel-title">{title}</h2> : <span />}
			{cta && channelUrl && (
				<a class="reel-cta" href={channelUrl} target="_blank" rel="noopener noreferrer">{cta}</a>
			)}
		</div>
	)}

	<div class="reel-grid">
		{videos.map((v, i) => (
			<button
				type="button"
				class={`tile t${(i % 3) + 1}`}
				data-video-id={v.id}
				data-video-title={v.title}
				aria-label={`Play: ${v.title}`}
			>
				<img
					class="tile-thumb"
					src={thumb(v.id)}
					data-fallback={thumb(v.id, true)}
					alt=""
					loading="lazy"
					decoding="async"
				/>
				<span class="tile-vignette" aria-hidden="true"></span>
				<span class="play" aria-hidden="true">
					<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
				</span>
				<span class="meta">
					{v.label && <span>{v.label}</span>}
					{v.duration && <span>{v.duration}</span>}
				</span>
			</button>
		))}
	</div>
</section>

<style>
	.reel {
		padding: 64px 40px 40px;
		border-top: 1px solid var(--color-rule);
	}

	.reel-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 24px;
		gap: 16px;
	}

	.reel-title {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 24px;
		color: #fff;
		letter-spacing: -0.01em;
	}

	.reel-cta {
		font-family: var(--font-mono);
		font-size: 11px;
		color: #888;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.reel-cta:hover { color: #fff; }

	.reel-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 14px;
	}

	.tile {
		aspect-ratio: 16 / 9;
		background: #0a0a0a;
		border: 1px solid var(--color-rule);
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
		cursor: pointer;
		padding: 0;
		font-family: inherit;
		color: inherit;
	}

	.tile-thumb {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.85;
		transition: opacity 0.2s ease;
	}

	.tile-vignette {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse at center, rgba(80, 40, 120, 0.35), rgba(0, 0, 0, 0.95));
		transition: opacity 0.2s ease;
		pointer-events: none;
	}

	.tile.t1 .tile-vignette {
		background: radial-gradient(ellipse at center, rgba(120, 40, 60, 0.35), rgba(0, 0, 0, 0.9));
	}
	.tile.t2 .tile-vignette {
		background: radial-gradient(ellipse at center, rgba(40, 90, 140, 0.35), rgba(0, 0, 0, 0.9));
	}

	.tile:hover .tile-vignette { opacity: 0.6; }
	.tile:hover .tile-thumb { opacity: 1; }

	.play {
		position: relative;
		width: 54px;
		height: 54px;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.5);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s ease, border-color 0.2s ease;
		background: rgba(0, 0, 0, 0.2);
	}

	.tile:hover .play {
		background: #fff;
		border-color: #fff;
	}

	.play svg {
		width: 18px;
		height: 18px;
		fill: #fff;
		margin-left: 3px;
		transition: fill 0.2s ease;
	}

	.tile:hover .play svg { fill: #000; }

	.meta {
		position: absolute;
		bottom: 14px;
		left: 16px;
		right: 16px;
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 9px;
		color: #ddd;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
	}

	.tile.is-playing .play,
	.tile.is-playing .meta,
	.tile.is-playing .tile-vignette,
	.tile.is-playing .tile-thumb { display: none; }

	.tile iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}

	@media (max-width: 820px) {
		.reel { padding: 32px 22px; }
		.reel-grid { grid-template-columns: 1fr; gap: 10px; }
		.reel-title { font-size: 18px; }
		.reel-cta { font-size: 9px; letter-spacing: 0.13em; }
		.play { width: 42px; height: 42px; }
		.play svg { width: 14px; height: 14px; margin-left: 2px; }
	}
</style>

<script>
	const tiles = document.querySelectorAll('.tile[data-video-id]');

	tiles.forEach((tile) => {
		const thumb = tile.querySelector('.tile-thumb');
		if (thumb instanceof HTMLImageElement) {
			thumb.addEventListener('error', () => {
				const fallback = thumb.dataset.fallback;
				if (fallback && thumb.src !== fallback) thumb.src = fallback;
			}, { once: true });
		}

		tile.addEventListener('click', () => {
			if (tile.classList.contains('is-playing')) return;
			const id = tile.getAttribute('data-video-id');
			const title = tile.getAttribute('data-video-title') ?? '';
			if (!id) return;
			const iframe = document.createElement('iframe');
			iframe.src = `https://www.youtube.com/embed/${encodeURIComponent(id)}?autoplay=1&rel=0`;
			iframe.title = title;
			iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
			iframe.allowFullscreen = true;
			tile.appendChild(iframe);
			tile.classList.add('is-playing');
		});
	});
</script>
