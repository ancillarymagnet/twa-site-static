---
export interface Props {
	production?: string;
	copyrightHolder: string;
	youtube?: string;
	instagram?: string;
}

const { production, copyrightHolder, youtube, instagram } = Astro.props;

const buildYear = new Date().getFullYear();
const holder = copyrightHolder.trim();
const hasLinks = Boolean(youtube || instagram);
---

<footer class="footer">
	<div class="left">
		{production && <p class="yfc">{production}</p>}
		<p class="copy">
			© <span class="js-current-year" data-build-year={buildYear}>{buildYear}</span>
			{holder ? ` ${holder}` : ''}
		</p>
	</div>
	{hasLinks && (
		<div class="links">
			{youtube && <a href={youtube} target="_blank" rel="noopener noreferrer">YouTube ↗</a>}
			{instagram && <a href={instagram} target="_blank" rel="noopener noreferrer">Instagram ↗</a>}
		</div>
	)}
</footer>

<script is:inline>
	const currentYear = new Date().getFullYear();
	for (const element of document.querySelectorAll('.js-current-year')) {
		const buildYear = Number(element.getAttribute('data-build-year'));
		if (!Number.isNaN(buildYear) && buildYear === currentYear) continue;
		element.textContent = String(currentYear);
	}
</script>

<style>
	.footer {
		padding: 48px 40px 32px;
		border-top: 1px solid var(--color-rule);
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		flex-wrap: wrap;
		gap: 24px;
		margin-top: auto;
	}

	.left {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.yfc {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 400;
		font-size: 16px;
		color: #b3b3b3;
		line-height: 1.35;
		max-width: 360px;
	}

	.copy {
		font-family: var(--font-mono);
		font-size: 11px;
		color: #888;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.links {
		display: flex;
		gap: 20px;
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.links a {
		color: #b3b3b3;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.links a:hover { color: var(--color-text); }

	@media (max-width: 820px) {
		.footer {
			padding: 28px 22px 22px;
			flex-direction: column;
			align-items: flex-start;
			gap: 16px;
		}

		.yfc { font-size: 14px; }
		.copy { font-size: 10px; letter-spacing: 0.14em; }
		.links { gap: 16px; font-size: 11px; letter-spacing: 0.13em; }
	}
</style>
