---
import { Image } from 'astro:assets';
import lockup from '../assets/lockup.png';

export interface Props {
	tagline: string;
	lockupAlt?: string;
}

const { tagline, lockupAlt = 'Third Wave' } = Astro.props;
---

<section class="hero">
	<div class="lockup">
		<Image src={lockup} alt={lockupAlt} loading="eager" />
	</div>
	{tagline && <h1 class="tagline">{tagline}</h1>}
</section>

<style>
	.hero {
		padding: 8px 40px 0;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.lockup {
		display: flex;
		justify-content: center;
		align-items: center;
		margin: 40px 0 28px;
		width: 100%;
	}

	.lockup img {
		max-width: 720px;
		width: 100%;
		height: auto;
		display: block;
	}

	.tagline {
		font-family: var(--font-serif);
		font-size: 32px;
		font-weight: 400;
		color: #fff;
		text-align: center;
		max-width: 560px;
		margin: 0 auto 32px;
		line-height: 1.1;
		letter-spacing: -0.015em;
	}

	@media (max-width: 820px) {
		.hero { padding: 8px 22px 0; }
		.lockup { margin: 18px 0 14px; }
		.lockup img { max-width: 88vw; }
		.tagline { font-size: 24px; margin-bottom: 24px; }
	}
</style>
