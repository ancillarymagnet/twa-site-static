---
import TopBar from './TopBar.astro';
import Ticker from './Ticker.astro';

export interface Props {
	status: string;
	meta?: string;
	ticker: string;
	ctaHref?: string;
	ctaText?: string;
	ctaExternal?: boolean;
}

const NAV_LINKS = [
	{ label: 'DEVELOPERS', href: '/dev' },
	{ label: 'PLATFORM', href: '/platform' },
];

const {
	status,
	meta,
	ticker,
	ctaHref = '/#signup',
	ctaText = 'GET INVITED',
	ctaExternal = false,
} = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<header class="header">
	<div class="header-inner">
		<div class="top-bar-slot"><TopBar status={status} meta={meta} /></div>
		<nav class="nav" aria-label="Primary">
			{NAV_LINKS.map((link) => (
				<a
					href={link.href}
					class:list={['nav-link', { active: currentPath === link.href }]}
					{...currentPath === link.href ? { 'aria-current': 'page' } : {}}
				>{link.label}</a>
			))}
			<a
				href={ctaHref}
				class="cta-link"
				{...ctaExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
			>{ctaText}</a>
		</nav>
		<button
			class="burger"
			type="button"
			aria-label="Menu"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>
	<div class="mobile-menu" id="mobile-menu">
		{NAV_LINKS.map((link) => (
			<a
				href={link.href}
				class:list={['menu-link', { active: currentPath === link.href }]}
				{...currentPath === link.href ? { 'aria-current': 'page' } : {}}
			>{link.label}</a>
		))}
		<div class="menu-status">
			<span class="ticket"><span class="dot" aria-hidden="true"></span>{status}</span>
			{meta && <span class="menu-meta">{meta}</span>}
		</div>
	</div>
	<Ticker copy={ticker} />
</header>

<script>
	const header = document.querySelector('.header');
	const burger = document.querySelector('.burger');
	if (header && burger) {
		burger.addEventListener('click', () => {
			const open = header.classList.toggle('menu-open');
			burger.setAttribute('aria-expanded', String(open));
		});
	}
</script>

<style>
	.header {
		background: var(--color-bg);
	}

	.header-inner {
		padding: 18px 40px 20px;
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.top-bar-slot {
		flex: 1;
		min-width: 0;
	}

	.nav {
		display: flex;
		align-items: center;
		gap: 24px;
		flex-shrink: 0;
		min-height: 38px;
		border-left: 1px solid var(--color-rule-strong);
		padding-left: 24px;
	}

	.nav-link {
		font-family: var(--font-label);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.nav-link:hover { color: var(--color-text); }

	.nav-link.active { color: var(--color-text); }

	.cta-link {
		font-family: var(--font-label);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text);
		background: transparent;
		border: 1px solid var(--color-text);
		text-decoration: none;
		padding: 9px 15px;
		min-width: 180px;
		text-align: center;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.cta-link:hover {
		background: var(--color-text);
		color: var(--color-bg);
	}

	.burger {
		display: none;
	}

	.mobile-menu {
		display: none;
	}

	@media (max-width: 820px) {
		.header-inner { padding: 14px 22px; gap: 12px; }

		.nav {
			gap: 0;
			min-height: 0;
			border-left: 0;
			padding-left: 0;
			margin-left: auto;
		}

		.nav .nav-link { display: none; }

		.cta-link { font-size: 11px; padding: 9px 14px; letter-spacing: 0.13em; min-width: 150px; }

		.burger {
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: stretch;
			gap: 5px;
			width: 38px;
			height: 38px;
			padding: 0 8px;
			background: transparent;
			border: 0;
			cursor: pointer;
			flex-shrink: 0;
		}

		.burger span {
			display: block;
			height: 1px;
			background: var(--color-text);
			transition: transform 0.2s ease, opacity 0.2s ease;
		}

		.menu-open .burger span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
		.menu-open .burger span:nth-child(2) { opacity: 0; }
		.menu-open .burger span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

		.menu-open .mobile-menu { display: block; }

		.mobile-menu {
			border-top: 1px solid var(--color-rule);
		}

		.menu-link {
			display: block;
			padding: 15px 22px;
			font-family: var(--font-label);
			font-size: 12px;
			font-weight: 600;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--color-muted);
			text-decoration: none;
			border-bottom: 1px solid var(--color-rule);
			transition: color 0.2s ease;
		}

		.menu-link:hover { color: var(--color-text); }

		.menu-link.active { color: var(--color-text); }

		.menu-status {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 15px 22px;
			font-family: var(--font-label);
			font-size: 10px;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: #888;
		}

		.ticket {
			display: flex;
			align-items: center;
			gap: 8px;
			white-space: nowrap;
		}

		.dot {
			width: 6px;
			height: 6px;
			border-radius: 50%;
			background: var(--color-text);
			box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
			animation: tw-pulse 1.8s ease-in-out infinite;
		}
	}
</style>
