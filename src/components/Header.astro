---
import TopBar from './TopBar.astro';
import Ticker from './Ticker.astro';

export interface Props {
	status: string;
	meta?: string;
	ticker: string;
	ctaHref?: string;
	ctaText?: string;
	ctaExternal?: boolean;
}

const NAV_LINKS = [
	{ label: 'DEVELOPERS', href: '/dev' },
	{ label: 'PLATFORM', href: '/platform' },
];

const { status, meta, ticker, ctaHref, ctaText, ctaExternal = false } = Astro.props;
const showCta = Boolean(ctaHref && ctaText);
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<header class="header">
	<div class="header-inner">
		<div class="top-bar-slot"><TopBar status={status} meta={meta} /></div>
		<nav class="nav" aria-label="Primary">
			{NAV_LINKS.map((link) => (
				<a
					href={link.href}
					class:list={['nav-link', { active: currentPath === link.href }]}
					{...currentPath === link.href ? { 'aria-current': 'page' } : {}}
				>{link.label}</a>
			))}
			{showCta && (
				<a
					href={ctaHref}
					class="cta-link"
					{...ctaExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
				>{ctaText}</a>
			)}
		</nav>
	</div>
	<Ticker copy={ticker} />
</header>

<style>
	.header {
		background: var(--color-bg);
	}

	.header-inner {
		padding: 18px 40px 20px;
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.top-bar-slot {
		flex: 1;
		min-width: 0;
	}

	.nav {
		display: flex;
		align-items: center;
		gap: 24px;
		flex-shrink: 0;
		min-height: 38px;
	}

	.nav-link {
		font-family: var(--font-label);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.nav-link:hover { color: var(--color-text); }

	.nav-link.active { color: var(--color-text); }

	.cta-link {
		font-family: var(--font-label);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text);
		background: transparent;
		border: 1px solid var(--color-text);
		text-decoration: none;
		padding: 9px 15px;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.cta-link:hover {
		background: var(--color-text);
		color: var(--color-bg);
	}

	@media (max-width: 820px) {
		.header-inner { padding: 14px 22px 18px; flex-wrap: wrap; }
		.top-bar-slot { flex-basis: 100%; }
		.nav { gap: 18px; width: 100%; }
		.nav-link { font-size: 11px; letter-spacing: 0.13em; }
		.cta-link { font-size: 11px; padding: 9px 14px; letter-spacing: 0.13em; margin-left: auto; }
	}
</style>
