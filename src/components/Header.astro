---
import TopBar from './TopBar.astro';
import Ticker from './Ticker.astro';

export interface Props {
	status: string;
	meta: string;
	metaHref?: string;
	ticker: string;
	ctaHref?: string;
	ctaText?: string;
	ctaExternal?: boolean;
}

const { status, meta, metaHref, ticker, ctaHref, ctaText, ctaExternal = false } = Astro.props;
const showCta = Boolean(ctaHref && ctaText);
---

<header class="header">
	<div class="header-inner">
		<div class="top-bar-slot"><TopBar status={status} meta={meta} metaHref={metaHref} /></div>
		{showCta && (
			<div class="cta-row">
				<a
					href={ctaHref}
					class="cta-link"
					{...ctaExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
				>{ctaText}</a>
			</div>
		)}
	</div>
	<Ticker copy={ticker} />
</header>

<style>
	.header {
		background: #000;
	}

	.header-inner {
		padding: 18px 40px 12px;
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.top-bar-slot {
		flex: 1;
		min-width: 0;
	}

	.cta-row {
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.cta-link {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #000;
		background: #fff;
		text-decoration: none;
		padding: 10px 16px;
		transition: opacity 0.2s ease;
	}

	.cta-link:hover { opacity: 0.85; }

	@media (max-width: 820px) {
		.header-inner { padding: 14px 22px 10px; }
		.cta-link { font-size: 11px; padding: 9px 14px; letter-spacing: 0.13em; }
	}
</style>
