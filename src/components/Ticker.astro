---
export interface Props {
	copy: string;
}

const { copy } = Astro.props;
---

<div class="ticker">
	<span class="track" aria-hidden="true">{copy + copy}</span>
	<span class="sr-only">{copy}</span>
</div>

<style>
	.ticker {
		padding: 11px 0;
		background: #fff;
		color: #000;
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.15em;
		white-space: nowrap;
		overflow: hidden;
		text-transform: uppercase;
		display: flex;
	}

	.track {
		display: inline-flex;
		flex-shrink: 0;
		animation: tw-scroll 60s linear infinite;
		will-change: transform;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 820px) {
		.ticker { font-size: 9px; letter-spacing: 0.13em; padding: 9px 0; }
		.track { animation-duration: 40s; }
	}

	@media (prefers-reduced-motion: reduce) {
		.track { animation: none; }
	}
</style>
