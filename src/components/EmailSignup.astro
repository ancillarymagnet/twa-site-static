---
export interface Props {
	placeholder: string;
	buttonText: string;
	description: string;
}

const { placeholder, buttonText, description } = Astro.props;
---

<section class="signup">
	<div class="signup-content">
		<p class="signup-description">{description}</p>
		<form class="signup-form" id="signup">
			<div class="form-group">
				<input
					type="email"
					placeholder={placeholder}
					required
					class="email-input"
					id="email-input"
				/>
				<button type="submit" class="submit-btn" id="submit-btn">{buttonText}</button>
			</div>
			<p class="form-message" id="form-message"></p>
		</form>
	</div>
</section>

<style>
	.signup {
		padding: 2rem 2rem;
		display: flex;
		justify-content: center;
	}

	.signup-content {
		max-width: 500px;
		width: 100%;
		text-align: center;
	}

	.signup-description {
		font-size: 1.1rem;
		margin-bottom: 1.5rem;
		color: var(--color-muted);
	}

	.form-group {
		display: flex;
		align-items: stretch;
		gap: 0.5rem;
		padding: 0.5rem;
		border-radius: 8px;
		border: 1px solid rgba(240, 237, 232, 0.2);
	}

	.email-input {
		flex: 1;
		background: transparent;
		border: none;
		padding: 0.8rem 1.2rem;
		color: var(--color-text);
		font-size: 1rem;
		outline: none;
		font-family: var(--font-body);
		font-weight: 400;
	}

	.email-input::placeholder {
		color: var(--color-muted);
	}

	.submit-btn {
		background: var(--color-accent);
		color: var(--color-bg);
		border: none;
		padding: 0.8rem 1.5rem;
		border-radius: 4px;
		flex-shrink: 0;
		font-weight: 600;
		font-size: 1rem;
		cursor: pointer;
		transition: opacity 0.2s ease;
		font-family: var(--font-heading);
		white-space: nowrap;
	}

	.submit-btn:hover {
		opacity: 0.85;
	}

	@media (max-width: 768px) {
		.signup {
			padding: 1.5rem 1.5rem;
		}

		.form-group {
			flex-direction: column;
			gap: 0;
			padding: 0;
			border: none;
			border-radius: 0;
		}

		.email-input {
			padding: 0.8rem 0.5rem;
			border-bottom: 1px solid rgba(240, 237, 232, 0.3);
		}

		.submit-btn {
			padding: 0.8rem 1.5rem;
			margin-top: 1rem;
			border-radius: 8px;
			width: 100%;
		}
	}

	.form-message {
		margin-top: 1rem;
		font-size: 0.9rem;
		color: var(--color-accent);
	}
</style>

<script>
	const form = document.getElementById('signup');
	const emailInput = document.getElementById('email-input');
	const submitBtn = document.getElementById('submit-btn');
	const message = document.getElementById('form-message');

	if (form && emailInput && submitBtn && message) {
		const initialButtonText = submitBtn.textContent ?? '';

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = emailInput.value;
			submitBtn.textContent = '...';
			submitBtn.disabled = true;

			try {
				const res = await fetch(
					'https://script.google.com/macros/s/AKfycbywTCoErcdOgjCLoFnVr7UZUfOjP0uEIHOd3owmGd3rblFg0Ams1tbmdCM-_tNqji3n/exec',
					{
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
						},
						body: JSON.stringify({ email }),
					}
				);

				if (!res.ok) {
					message.textContent = 'Something went wrong. Try again.';
					return;
				}

				message.textContent = "You're in!";
				emailInput.value = '';
			} catch {
				message.textContent = 'Something went wrong. Try again.';
			} finally {
				submitBtn.textContent = initialButtonText;
				submitBtn.disabled = false;
			}
		});
	}
</script>
