---
export interface Props {
	placeholder: string;
	buttonText: string;
	description?: string;
	cueText?: string;
}

const { placeholder, buttonText, description, cueText = 'See it in motion' } = Astro.props;
---

<section class="signup-wrap">
	{description && <p class="signup-description">{description}</p>}
	<form class="signup-form" id="signup">
		<div class="form-group">
			<input
				type="email"
				placeholder={placeholder}
				required
				class="email-input"
				id="email-input"
				aria-describedby="form-message"
				aria-label="Email address"
			/>
			<button type="submit" class="submit-btn" id="submit-btn">{buttonText}</button>
		</div>
		<p class="form-message" id="form-message" role="status" aria-live="polite"></p>
	</form>

	{cueText && (
		<div class="cue">
			{cueText}
			<span class="arrow" aria-hidden="true">↓</span>
		</div>
	)}
</section>

<style>
	.signup-wrap {
		padding: 0 40px 32px;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.signup-description {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-muted);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		margin-bottom: 14px;
		text-align: center;
	}

	.signup-form {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
	}

	.form-group {
		display: flex;
		width: 100%;
		max-width: 480px;
		border: 1px solid var(--color-rule-strong);
	}

	.email-input {
		flex: 1;
		min-width: 0;
		background: transparent;
		border: 0;
		padding: 16px 18px;
		color: #fff;
		font-size: 16px;
		outline: none;
		font-family: inherit;
	}

	.email-input::placeholder {
		color: #666;
	}

	.email-input[aria-invalid='true'] {
		outline: 1px solid #c87a5e;
		outline-offset: -1px;
	}

	.submit-btn {
		background: #fff;
		border: 0;
		color: #000;
		padding: 0 28px;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.14em;
		font-family: var(--font-mono);
		cursor: pointer;
		text-transform: uppercase;
		transition: opacity 0.2s ease;
		flex-shrink: 0;
	}

	.submit-btn:hover { opacity: 0.85; }
	.submit-btn:disabled { cursor: progress; opacity: 0.7; }

	.form-message {
		margin-top: 12px;
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #b3b3b3;
		text-align: center;
	}

	.cue {
		margin-top: 32px;
		text-align: center;
		font-family: var(--font-mono);
		font-size: 12px;
		color: #b3b3b3;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding-top: 32px;
	}

	.cue .arrow {
		display: block;
		margin-top: 8px;
		font-size: 16px;
		color: #b3b3b3;
		animation: tw-bob 2.4s ease-in-out infinite;
	}

	@media (prefers-reduced-motion: reduce) {
		.cue .arrow { animation: none; }
	}

	@media (max-width: 820px) {
		.signup-wrap { padding: 0 22px 28px; }

		.form-group {
			flex-direction: column;
			border: 0;
			gap: 8px;
		}

		.email-input {
			border: 1px solid var(--color-rule-strong);
			padding: 16px 16px;
			font-size: 16px;
		}

		.submit-btn {
			padding: 16px;
			width: 100%;
			font-size: 13px;
		}

		.cue { margin-top: 18px; padding-top: 24px; font-size: 11px; }
	}
</style>

<script>
	const form = document.getElementById('signup');
	const emailInput = document.getElementById('email-input');
	const submitBtn = document.getElementById('submit-btn');
	const message = document.getElementById('form-message');

	const isPlausibleEmail = (value) => /^[^@\s]+@[^@\s]+$/.test(value);

	if (!form || !emailInput || !submitBtn || !message) {
		console.error('Email signup initialization failed: required DOM elements not found.');
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Unavailable';
		}
		if (message) {
			message.textContent = 'Signup is temporarily unavailable.';
		}
	} else if (!form.dataset.signupBound) {
		form.dataset.signupBound = 'true';
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			message.textContent = '';
			const email = emailInput.value.trim();

			if (!isPlausibleEmail(email)) {
				emailInput.setAttribute('aria-invalid', 'true');
				message.textContent = 'Enter a valid email address.';
				return;
			}

			emailInput.removeAttribute('aria-invalid');

			message.textContent = 'Submitting…';
			const previousButtonText = submitBtn.textContent ?? '';
			submitBtn.textContent = '...';
			submitBtn.disabled = true;

			try {
				await fetch(
					'https://script.google.com/macros/s/AKfycbywTCoErcdOgjCLoFnVr7UZUfOjP0uEIHOd3owmGd3rblFg0Ams1tbmdCM-_tNqji3n/exec',
					{
						method: 'POST',
						body: JSON.stringify({ email }),
						mode: 'no-cors',
					}
				);

				message.textContent = "You're in.";
				emailInput.value = '';
				emailInput.removeAttribute('aria-invalid');
			} catch (err) {
				console.error('Network error during signup', err);
				message.textContent = 'Network error. Try again.';
			} finally {
				submitBtn.textContent = previousButtonText;
				submitBtn.disabled = false;
			}
		});

		emailInput.addEventListener('focus', () => {
			emailInput.removeAttribute('aria-invalid');
			if (message.textContent !== "You're in.") {
				message.textContent = '';
			}
		});
	}
</script>
