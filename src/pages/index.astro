---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import EmailSignup from '../components/EmailSignup.astro';
import YouTubeSection from '../components/YouTubeSection.astro';
import Footer from '../components/Footer.astro';

import { getEntry } from 'astro:content';

const siteEntry = await getEntry('site', 'site');
const siteData = siteEntry.data;
---

<Layout
	title={siteData.seo.title}
	description={siteData.seo.description}
	socialDescription={siteData.seo.socialDescription}
>
	<Header
		status={siteData.topBar.status}
		meta={siteData.topBar.meta}
		ticker={siteData.ticker}
	/>

	<main>
		<Hero tagline={siteData.hero.title} />

		<EmailSignup
			placeholder={siteData.signup.placeholder}
			buttonText={siteData.signup.buttonText}
			description={siteData.signup.description}
		/>

		<YouTubeSection
			title={siteData.reel.title}
			cta={siteData.reel.cta}
			channelUrl={siteData.social.youtube}
			videos={siteData.reel.videos}
		/>
	</main>

	<Footer
		production={siteData.footer.production}
		copyrightHolder={siteData.footer.copyrightHolder}
		youtube={siteData.social.youtube}
		instagram={siteData.social.instagram}
	/>
</Layout>

<style>
	main {
		flex: 1;
		display: flex;
		flex-direction: column;
	}
</style>
