---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const siteEntry = await getEntry('site', 'site');
const siteData = siteEntry.data;

const LICENSING_EMAIL = 'licensing@thirdwave.fun';
const MAILTO_URL = `mailto:${LICENSING_EMAIL}?subject=${encodeURIComponent('Platform licensing')}`;
---

<Layout
	title="Third Wave — Platform Licensing"
	description="License the Third Wave platform for your venue. Guests' phones become controllers for one collective experience on your big screen. No goggles, no controllers, no hardware to manage."
	socialDescription="Your space. Your story. Our platform. License Third Wave for your venue."
>
	<Header
		status={siteData.topBar.status}
		meta={siteData.topBar.meta}
		ticker={siteData.ticker}
		ctaHref={MAILTO_URL}
		ctaText="TALK TO US"
	/>

	<main>
		<section class="platform">
			<p class="eyebrow">Platform</p>
			<h1 class="platform-title">Your space.<br/>Your story.<br/>Our&nbsp;platform.</h1>

			<p class="platform-lede">
				Third Wave runs our own shows in movie theaters. The same platform
				is available to license for yours.
			</p>

			<p class="platform-sub">
				Any room with a big screen becomes a venue for shared play: a
				planetarium dome, a black-box gallery, a 300-seat theater, the weird
				hallway you never figured out. Guests' own phones become rich
				controllers. Touch, tilt, voice, individual screens for every player,
				all driving one collective experience on yours.
			</p>

			<div class="features">
				<div class="feature">
					<h2>Nothing to hand out. Nothing to sanitize.</h2>
					<p>
						No goggles, no controllers, no charging carts, no hardware
						graveyard in a back closet. Guests scan and they're in.
						Throughput stays high and the operational footprint stays
						close to zero.
					</p>
				</div>

				<div class="feature">
					<h2>Built by your team, or ours.</h2>
					<p>
						Your creative stays yours. SDKs for Unity, Unreal,
						TouchDesigner, and TypeScript mean your in-house team or your
						usual production partners build directly on the platform. If
						you'd rather not, we design and build alongside you.
					</p>
				</div>

				<div class="feature">
					<h2>Built to run all day.</h2>
					<p>
						Host it in your venue or let us run it in the cloud. Either
						way, it's infrastructure built to run sessions all day, every
						day, for hundreds of phones in a room or a thousand across
						your venue.
					</p>
				</div>
			</div>

			<a class="cta" href={MAILTO_URL}>TALK TO US ABOUT LICENSING</a>

			<p class="cta-note">{LICENSING_EMAIL}</p>
		</section>
	</main>

	<Footer
		production={siteData.footer.production}
		copyrightHolder={siteData.footer.copyrightHolder}
		youtube={siteData.social.youtube}
		instagram={siteData.social.instagram}
	/>
</Layout>

<style>
	main {
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.platform {
		padding: 64px 40px 80px;
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.eyebrow {
		font-family: var(--font-label);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #888;
		margin-bottom: 24px;
	}

	.platform-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(40px, 7vw, 68px);
		line-height: 0.95;
		letter-spacing: -0.025em;
		text-transform: uppercase;
		color: var(--color-text);
		margin-bottom: 28px;
	}

	.platform-lede {
		font-family: var(--font-sans);
		font-size: 18px;
		font-weight: 400;
		line-height: 1.5;
		color: var(--color-text);
		margin-bottom: 16px;
		max-width: 560px;
	}

	.platform-sub {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.55;
		color: #b3b3b3;
		margin-bottom: 56px;
		max-width: 560px;
	}

	.features {
		display: flex;
		flex-direction: column;
		gap: 40px;
		margin-bottom: 56px;
	}

	.feature h2 {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 22px;
		letter-spacing: -0.01em;
		color: var(--color-text);
		margin-bottom: 10px;
	}

	.feature p {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.55;
		color: #b3b3b3;
		max-width: 560px;
		margin: 0 auto;
	}

	.cta {
		display: inline-block;
		font-family: var(--font-label);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-bg);
		background: var(--color-text);
		padding: 16px 28px;
		text-decoration: none;
		transition: opacity 0.2s ease, transform 0.15s ease;
	}

	.cta:hover { opacity: 0.9; transform: translateY(-1px); }
	.cta:active { transform: translateY(0); }

	.cta-note {
		margin-top: 16px;
		font-family: var(--font-label);
		font-size: 11px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #b3b3b3;
	}

	@media (max-width: 820px) {
		.platform { padding: 40px 22px 56px; }
		.features { gap: 32px; margin-bottom: 48px; }
		.cta { display: block; width: 100%; }
	}
</style>
