---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const siteEntry = await getEntry('site', 'site');
const siteData = siteEntry.data;

const FORM_URL = 'https://tally.so/r/WOoYxP';
---

<Layout
	title="Third Wave — Developer Beta"
	description="The Third Wave dev kit is in closed beta. Request access to build location-based, phone-as-controller experiences on our platform."
	socialDescription="Build on Third Wave. Dev kit access is in closed beta — request an invite."
>
	<Header
		status={siteData.topBar.status}
		meta="← BACK"
		metaHref="/"
		ticker={siteData.ticker}
		ctaHref={FORM_URL}
		ctaText="REQUEST ACCESS"
		ctaExternal={true}
	/>

	<main>
		<section class="dev">
			<p class="eyebrow">Developers</p>
			<h1 class="dev-title">Build on<br/>Third&nbsp;Wave.</h1>

			<p class="dev-lede">
				Our dev kit is in closed beta. We're working hands-on with a
				small group of studios and creators to shape the first things built.
			</p>

			<p class="dev-sub">
				If you're making interactive experiences and want to blow some wigs
				back in a new medium, we want to hear from you.
			</p>

			<a
				class="cta"
				href={FORM_URL}
				target="_blank"
				rel="noopener noreferrer"
			>REQUEST DEV KIT ACCESS</a>

			<p class="cta-note">Takes about 2 minutes<br />we read every submission.</p>
		</section>
	</main>

	<Footer
		production={siteData.footer.production}
		copyrightHolder={siteData.footer.copyrightHolder}
		youtube={siteData.social.youtube}
		instagram={siteData.social.instagram}
	/>
</Layout>

<style>
	main {
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.dev {
		padding: 64px 40px 80px;
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.eyebrow {
		font-family: var(--font-label);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #888;
		margin-bottom: 24px;
	}

	.dev-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(48px, 8vw, 80px);
		line-height: 0.95;
		letter-spacing: -0.025em;
		text-transform: uppercase;
		color: var(--color-text);
		margin-bottom: 28px;
	}

	.dev-lede {
		font-family: var(--font-sans);
		font-size: 18px;
		font-weight: 400;
		line-height: 1.5;
		color: var(--color-text);
		margin-bottom: 16px;
		max-width: 560px;
	}

	.dev-sub {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.55;
		color: var(--color-muted);
		margin-bottom: 36px;
		max-width: 520px;
	}

	.cta {
		display: inline-block;
		font-family: var(--font-label);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-bg);
		background: var(--color-text);
		padding: 16px 28px;
		text-decoration: none;
		transition: opacity 0.2s ease, transform 0.15s ease;
	}

	.cta:hover { opacity: 0.9; transform: translateY(-1px); }
	.cta:active { transform: translateY(0); }

	.cta-note {
		margin-top: 16px;
		font-family: var(--font-label);
		font-size: 11px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #b3b3b3;
	}

	@media (max-width: 820px) {
		.dev { padding: 40px 22px 56px; }
		.cta { display: block; width: 100%; }
	}
</style>
